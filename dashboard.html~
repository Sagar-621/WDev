                        reviewProductSelect.innerHTML = items.map((item) => {
                            const label = `${item.name || item.product_name || 'Product'}${item.size ? ` · Size ${item.size}` : ''}${item.quantity ? ` · Qty ${item.quantity}` : ''}`;
