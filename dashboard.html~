            async function openOrderReviewModal(orderId, orderRef) {
                try {
                    const reviewUrls = [
                        `${API_BASE}/api/reviews/orders/${orderId}/reviewable-items`
                    ];
                    let res = null;
                    let data = null;

                    for (const url of reviewUrls) {
                        const response = await fetch(url, { headers });
                        const contentType = response.headers.get('content-type') || '';
                        if (!response.ok || !contentType.includes('application/json')) {
                            continue;
                        }

                        res = response;
                        data = await response.json();
                        break;
                    }

                    if (!data || !data.success || !Array.isArray(data.items)) {
                        showToast((data && data.message) ? data.message : 'Unable to open review form');
                        return;
                    }

                    const reviewableItems = data.items.filter(item => item && item.can_review);
                    if (!reviewableItems.length) {
                        const alreadyReviewed = data.items.some(item => item && item.is_reviewed);
                        showToast(alreadyReviewed ? 'You already reviewed this order' : 'No reviewable items yet');
                        return;
                    }

                    openReviewModal({
                        order_id: Number(data.order_id || orderId) || orderId,
                        order_ref: orderRef,
                        items: reviewableItems,
                        selectedOrderItemId: reviewableItems[0].order_item_id
                    });
                } catch (err) {
                    console.error(err);
                    showToast('Failed to open review form');
                }
            }

            async function submitReview() {
                if (!activeReviewContext) return;
                const rating = Number(submitReviewBtn.dataset.rating || 0);
                if (rating < 1 || rating > 5) {
                    showToast('Please choose a rating');
                    return;
                }

                const selectedItem = getSelectedReviewItem();
                if (!selectedItem) {
                    showToast('No reviewable product found');
                    return;
                }

                submitReviewBtn.disabled = true;
                submitReviewBtn.textContent = 'Submitting...';
                try {
                    const reviewOrderId = activeReviewContext.order_id;
                    const reviewUrls = [
                        `${API_BASE}/api/reviews`
                    ];
                    const payload = {
                        order_id: activeReviewContext.order_id,
                        order_item_id: selectedItem.order_item_id,
                        product_id: selectedItem.product_id,
                        rating,
                        review_text: reviewTextInput.value.trim()
                    };

                    let data = null;
                    for (const url of reviewUrls) {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers,
                            body: JSON.stringify(payload)
                        });
                        const contentType = response.headers.get('content-type') || '';
                        if (!response.ok || !contentType.includes('application/json')) {
                            continue;
                        }
                        data = await response.json();
                        break;
                    }

                    if (!data || !data.success) {
                        showToast((data && data.message) ? data.message : 'Failed to submit review');
                        return;
                    }

                    showToast('Review submitted successfully', 'success');
                    try {
                        const productId = Number(selectedItem?.product_id || 0) || null;
                        const refreshPayload = JSON.stringify({ productId, timestamp: Date.now() });
                        localStorage.setItem('DEVASTHRA_reviews_refresh', refreshPayload);
                        window.dispatchEvent(new CustomEvent('DEVASTHRA_REVIEWS_UPDATED', { detail: { productId } }));
                    } catch { }
                    closeReviewModal();
                    if (orderModalOverlay?.classList.contains('open')) {
                        await openOrderItems(reviewOrderId);
                    } else {
                        await loadOrders();
                    }
                } catch (err) {
                    showToast('Failed to submit review');
                } finally {
                    submitReviewBtn.disabled = false;
                    submitReviewBtn.textContent = 'Submit Review';
                }
            }

            function closeModal() {
