                    btn.addEventListener('click', () => {
                        setReviewRating(Number(btn.dataset.rating || 0));
                    });
                });
                if (reviewProductSelect) {
                    reviewProductSelect.onchange = () => {
                        renderReviewModalTarget();
                    };
