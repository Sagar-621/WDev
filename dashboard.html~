            function getReviewableItemsFromContext() {
                if (!activeReviewContext || !Array.isArray(activeReviewContext.items)) return [];
                return activeReviewContext.items.filter(item => item && (item.can_review || activeReviewContext.forceReviewable));
            }

            function getSelectedReviewItem() {
                const items = getReviewableItemsFromContext();
                if (!items.length) return null;
                const selectedId = Number(reviewProductSelect?.value || activeReviewContext?.selectedOrderItemId || items[0].order_item_id);
                return items.find(item => Number(item.order_item_id) === selectedId) || items[0];
            }

            function renderReviewModalTarget() {
                if (!activeReviewContext) {
                    reviewTargetInfo.textContent = '';
                    return;
                }

                const items = getReviewableItemsFromContext();
                const selectedItem = getSelectedReviewItem() || items[0] || {};
                const orderLabel = escapeHtml(activeReviewContext.order_ref || `#${activeReviewContext.order_id || ''}`);
                const productLabel = escapeHtml(selectedItem.name || selectedItem.product_name || 'Product');
                const sizeLabel = escapeHtml(selectedItem.size || 'N/A');
                const quantityLabel = escapeHtml(String(selectedItem.quantity || 1));

                reviewTargetInfo.innerHTML = `
