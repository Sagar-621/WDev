            function setReviewRating(rating) {
                reviewStarRow?.querySelectorAll('.dash-review-star').forEach(btn => {
                    const btnRating = Number(btn.dataset.rating || 0);
                    btn.classList.toggle('active', btnRating <= rating);
                });
                if (submitReviewBtn) submitReviewBtn.dataset.rating = String(rating);
