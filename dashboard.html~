    <div class="toast" id="toast">
        <span class="toast-icon">✓</span>
        <span id="toastMessage"></span>
    </div>

    <script>
        const API_BASE = window.__API_BASE || (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' || window.location.protocol === 'file:' ? 'http://localhost:5000' : window.location.origin);

        document.addEventListener('DOMContentLoaded', () => {
            const getToken = () => localStorage.getItem('DEVASTHRA_token');
            const getUser = () => { try { return JSON.parse(localStorage.getItem('DEVASTHRA_user')); } catch { return null; } };

            if (!getToken() || !getUser()) {
                window.location.href = 'index.html';
                return;
            }

            const token = getToken();
            const headers = { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' };

            const toast = document.getElementById('toast');
            const toastMessage = document.getElementById('toastMessage');
            let toastTimeout;

            function showToast(msg, type = 'info') {
                clearTimeout(toastTimeout);
                toastMessage.textContent = msg;
                toast.className = `toast show ${type}`;
                toastTimeout = setTimeout(() => toast.classList.remove('show'), 3200);
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function normalizeAddressDisplay(address) {
                const recipientName = String(address?.recipient_name || '').trim();
                const recipientPhone = String(address?.recipient_phone || '').trim();
                const fallbackName = String(address?.name || '').trim();
                const fallbackPhone = String(address?.mobile || '').trim();

                return {
                    ...address,
                    displayName: recipientName || fallbackName,
                    displayPhone: recipientPhone || fallbackPhone
                };
            }

            const getImageUrl = (url) => {
                if (!url) return 'https://via.placeholder.com/300?text=No+Image';
                if (url.startsWith('http')) return url;
                // Handle both with and without leading slash
                return url.startsWith('/') ? `${API_BASE}${url}` : `${API_BASE}/${url}`;
            };

            const fmt = value => '₹' + Number(value || 0).toLocaleString('en-IN');
            const fmtDate = value => {
                if (!value) return '—';
                const date = new Date(value);
                return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
            };
            const statusClass = status => {
                const s = String(status || '').toLowerCase();
                if (['paid', 'delivered', 'success'].includes(s)) return 'dash-status-success';
                if (['pending', 'created'].includes(s)) return 'dash-status-pending';
                if (['shipped', 'packed'].includes(s)) return 'dash-status-info';
                if (['cancelled', 'failed'].includes(s)) return 'dash-status-error';
                return 'dash-status-default';
            };

            const fmtDateTime = value => {
                if (!value) return 'Not available';
                const date = new Date(value);
                return date.toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' });
            };

            function mapShipmentPresentation(orderStatus, shipmentStatus) {
                const normalizedShipment = String(shipmentStatus || '').trim().toUpperCase();
                const normalizedOrder = String(orderStatus || '').trim().toUpperCase();

                if (normalizedOrder === 'CANCELLED' || normalizedShipment.includes('CANCEL')) {
                    return { orderLabel: 'Cancelled', shipmentLabel: 'Cancelled', stepIndex: -1 };
                }
                if (normalizedOrder === 'DELIVERED' || normalizedShipment === 'DELIVERED') {
                    return { orderLabel: 'Delivered', shipmentLabel: 'Delivered', stepIndex: 4 };
                }
                if (normalizedOrder === 'SHIPPED') {
                    return { orderLabel: 'Shipped', shipmentLabel: shipmentStatus || 'Shipped', stepIndex: 2 };
                }
                if (normalizedOrder === 'PACKED') {
                    return { orderLabel: 'Packed', shipmentLabel: shipmentStatus || 'Packed', stepIndex: 1 };
                }
                if (normalizedOrder === 'PAID') {
                    return { orderLabel: 'Paid', shipmentLabel: shipmentStatus || 'Paid', stepIndex: 0 };
                }
                if (normalizedOrder === 'PENDING') {
                    return { orderLabel: 'Pending', shipmentLabel: shipmentStatus || 'Pending', stepIndex: 0 };
                }
                if (normalizedShipment.includes('RTO') || normalizedShipment.includes('RETURNING')) {
                    return { orderLabel: 'Returning to seller', shipmentLabel: 'Returning to seller', stepIndex: -2 };
                }
                if (normalizedShipment === 'OUT FOR DELIVERY') {
                    return { orderLabel: 'Out for delivery', shipmentLabel: 'Out for delivery', stepIndex: 3 };
                }
                if (
                    normalizedShipment === 'PICKED UP' ||
                    normalizedShipment === 'IN TRANSIT' ||
                    normalizedShipment === 'REACHED DESTINATION CITY' ||
                    normalizedShipment === 'REACHED DESTINATION HUB' ||
                    normalizedShipment.includes('TRANSIT') ||
                    normalizedShipment.includes('REACHED DESTINATION')
                ) {
                    return { orderLabel: 'Shipped', shipmentLabel: 'Shipped', stepIndex: 2 };
                }
                if (
                    normalizedShipment === 'READY TO SHIP' ||
                    normalizedShipment === 'CONFIRMED' ||
                    normalizedShipment === 'PACKED' ||
                    normalizedShipment === 'AWB ASSIGNED' ||
                    normalizedShipment === 'MANIFEST GENERATED' ||
                    normalizedShipment === 'PICKUP SCHEDULED' ||
                    normalizedShipment.includes('READY TO SHIP') ||
                    normalizedShipment.includes('AWB') ||
                    normalizedShipment.includes('MANIFEST') ||
                    normalizedShipment.includes('PICKUP')
                ) {
                    return { orderLabel: 'Packed', shipmentLabel: 'Packed', stepIndex: 1 };
                }
                if (normalizedShipment === 'NEW' || normalizedShipment.includes('NEW')) {
                    return { orderLabel: 'Ordered', shipmentLabel: 'Ordered', stepIndex: 0 };
                }

                return {
                    orderLabel: orderStatus || 'Ordered',
                    shipmentLabel: shipmentStatus || 'Tracking pending',
                    stepIndex: 0
                };
            }

            function renderDashboardTrackingSummary(order) {
                if (!order) return '';

                const shipmentStatus = order.shiprocket_system_status || order.shiprocket_display_status || order.shiprocket_tracking_status || order.shiprocket_status || '';
                const latestMessage = order.shiprocket_user_message || order.shiprocket_latest_activity || '';
                const hasTracking = Boolean(order.shiprocket_shipment_id || order.shiprocket_awb_code || shipmentStatus || latestMessage);
                if (!hasTracking) return '';

                const steps = ['Ordered', 'Packed', 'Shipped', 'Out for delivery', 'Delivered'];
                const presentation = mapShipmentPresentation(order.status, shipmentStatus);
                const stepIndex = presentation.stepIndex;
                let progressBlock = '';

                if (stepIndex === -1) {
                    progressBlock = `<div class="dash-tracking-alert cancelled">Order cancelled</div>`;
                } else if (stepIndex === -2) {
                    progressBlock = `<div class="dash-tracking-alert rto">Shipment is returning to seller</div>`;
                } else {
                    progressBlock = `
                        <div class="dash-tracking-stepper fill-${Math.max(1, Math.min(stepIndex + 1, 5))}">
                            ${steps.map((step, index) => {
                                const stateClass = index < stepIndex ? 'done' : index === stepIndex ? 'active' : '';
                                return `
                                    <div class="dash-tracking-step ${stateClass}">
                                        <div class="dash-tracking-step-dot"></div>
                                        <div class="dash-tracking-step-label">${escapeHtml(step)}</div>
                                    </div>
                                `;
                            }).join('')}
                        </div>
                    `;
                }

                const entries = [
                    ['Order Status', presentation.orderLabel],
                    ['Shipment Status', presentation.shipmentLabel],
                    ['Shipment Update', latestMessage || 'We will update this here as soon as the shipment moves.'],
                    ['Courier', order.shiprocket_courier_name || 'Awaiting assignment'],
                    ['Shipment ID', order.shiprocket_shipment_id || 'Pending'],
                    ['AWB', order.shiprocket_awb_code || 'Pending'],
                    ['Updated At', fmtDateTime(order.shiprocket_latest_activity_at)]
                ];

                return `
                    <div class="dash-tracking-box">
                        <h4>Shipment Tracking</h4>
                        ${progressBlock}
                        <div class="dash-tracking-grid">
                            ${entries.map(([label, value]) => `
                                <div class="dash-tracking-meta">
                                    <span class="dash-tracking-label">${escapeHtml(label)}</span>
                                    <span class="dash-tracking-value">${escapeHtml(value)}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            // Sidebar navigation
            const navItems = document.querySelectorAll('.dash-nav-item[data-section], .dash-mobile-tab[data-section]');
            const sections = document.querySelectorAll('.dash-section');

            async function switchSection(section) {
                navItems.forEach(item => item.classList.toggle('active', item.dataset.section === section));
                sections.forEach(node => node.classList.toggle('active', node.id === `sec-${section}`));

                document.getElementById('dashSidebar').classList.remove('open');
                document.getElementById('dashSidebarOverlay').classList.remove('visible');
                document.body.style.overflow = '';

                if (section === 'orders') await loadOrders();
                if (section === 'payments') await loadPayments();
                if (section === 'addresses') await loadAddresses();
                if (section === 'profile') await loadProfile();
                if (section === 'support') await loadSupportConversation();
            }

            navItems.forEach(item => {
                item.addEventListener('click', () => switchSection(item.dataset.section));
            });

            // Header scroll behavior
            window.addEventListener('scroll', () => {
                document.getElementById('header')?.classList.toggle('scrolled', window.pageYOffset > 10);
            }, { passive: true });

            // User dropdown
            const userBtn = document.getElementById('userIconBtn');
            const userDrop = document.getElementById('userDropdown');
            const guestMenu = document.getElementById('guestMenu');
            const loggedMenu = document.getElementById('loggedMenu');

            function updateHeaderUserUI() {
                const user = getUser();
                if (user && getToken()) {
                    if (guestMenu) guestMenu.style.display = 'none';
                    if (loggedMenu) {
                        loggedMenu.style.display = 'block';
                        const info = document.getElementById('dropdownUserInfo');
                        if (info) info.textContent = user.name || user.mobile || 'My Account';
                    }
                } else {
                    if (guestMenu) guestMenu.style.display = 'block';
                    if (loggedMenu) loggedMenu.style.display = 'none';
                }
            }
            updateHeaderUserUI();

            userBtn?.addEventListener('click', (e) => {
                e.stopPropagation();
                userDrop?.classList.toggle('open');
            });
            document.addEventListener('click', () => userDrop?.classList.remove('open'));

            document.getElementById('logoutBtn')?.addEventListener('click', () => {
                localStorage.removeItem('DEVASTHRA_token');
                localStorage.removeItem('DEVASTHRA_user');
                window.location.href = 'index.html';
            });

            // Logout from sidebar
            document.getElementById('dashLogoutBtn')?.addEventListener('click', () => {
                localStorage.removeItem('DEVASTHRA_token');
                localStorage.removeItem('DEVASTHRA_user');
                showToast('Logged out successfully', 'success');
                setTimeout(() => { window.location.href = 'index.html'; }, 500);
            });

            // Order Details Modal Logic
            const orderModalOverlay = document.getElementById('orderItemsOverlay');
            const orderItemsList = document.getElementById('orderItemsList');
            const modalOrderTitle = document.getElementById('modalOrderTitle');
            const closeOrderModal = document.getElementById('closeOrderModal');
            const modalCloseBtn = document.getElementById('modalCloseBtn');
            const cancelRequestOverlay = document.getElementById('cancelRequestOverlay');
            const closeCancelRequestModal = document.getElementById('closeCancelRequestModal');
            const cancelRequestDismissBtn = document.getElementById('cancelRequestDismissBtn');
            const submitCancelRequestBtn = document.getElementById('submitCancelRequestBtn');
            const cancelOtherWrap = document.getElementById('cancelOtherWrap');
            const cancelOtherReason = document.getElementById('cancelOtherReason');
            const cancelRequestOrderId = document.getElementById('cancelRequestOrderId');
            const reviewOverlay = document.getElementById('reviewOverlay');
            const closeReviewModalBtn = document.getElementById('closeReviewModal');
            const cancelReviewModalBtn = document.getElementById('cancelReviewModalBtn');
