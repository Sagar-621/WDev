            function openReviewModal(context) {
                activeReviewContext = {
                    order_id: context.order_id,
                    order_ref: context.order_ref || `#${context.order_id || ''}`,
                    items: Array.isArray(context.items) ? context.items : [context],
                    selectedOrderItemId: context.selectedOrderItemId || context.order_item_id || null,
