            async function openOrderItems(orderId, orderRef = '') {
                modalOrderTitle.textContent = orderRef ? String(orderRef) : 'Order Details';
                orderItemsList.innerHTML = '<div class="dash-loading"><div class="spinner"></div><p>Fetching items...</p></div>';
                orderModalOverlay.classList.add('open');

                try {
                    const res = await fetch(`${API_BASE}/orders/${orderId}`, { headers });
                    const data = await res.json();

                    if (!data.success) {
                        orderItemsList.innerHTML = `<p class="dash-error">${data.message || 'Failed to fetch items'}</p>`;
                        return;
                    }

                    if (!data.items || data.items.length === 0) {
                        orderItemsList.innerHTML = '<p>No items found for this order.</p>';
                        return;
                    }

                    let reviewMap = new Map();
                    let reviewOrderStatus = String(data.order?.status || '').trim();
                    try {
                        const reviewRes = await fetch(`${API_BASE}/api/reviews/orders/${orderId}/reviewable-items`, { headers });
                        const reviewData = await reviewRes.json();
                        if (reviewData.success && Array.isArray(reviewData.items)) {
                            reviewOrderStatus = String(reviewData.order_status || reviewOrderStatus).trim();
                            reviewMap = new Map(reviewData.items.map(item => [Number(item.order_item_id), item]));
                        }
                    } catch {
                        reviewMap = new Map();
                    }

                    const modalStatus = String(reviewOrderStatus || data.order?.status || '').trim().toLowerCase();
                    const cancelRequestStatus = String(data.order?.cancellation_request_status || '').trim().toLowerCase();
                    const canCancel = (modalStatus === 'pending' || modalStatus === 'paid') && cancelRequestStatus !== 'requested';
                    const returnBlock = await loadDashboardReturnEligibility(orderId, data.order?.invoice_number || `#${orderId}`);
                    modalOrderTitle.textContent = data.order?.invoice_number || orderRef || 'Order Details';

                    const orderSummaryBlock = `
                        <div class="dash-modal-summary">
                            <div class="dash-modal-summary-card">
                                <span>Order Ref</span>
                                <strong>${escapeHtml(data.order?.invoice_number || `#${orderId}`)}</strong>
                            </div>
                            <div class="dash-modal-summary-card">
                                <span>Placed On</span>
                                <strong>${escapeHtml(fmtDate(data.order?.created_at))}</strong>
                            </div>
                            <div class="dash-modal-summary-card">
                                <span>Payment</span>
                                <strong>${escapeHtml(data.order?.payment_method || 'Prepaid')}</strong>
                            </div>
                            <div class="dash-modal-summary-card">
                                <span>Total</span>
                                <strong>${escapeHtml(fmt(data.order?.total_amount || 0))}</strong>
                            </div>
                        </div>
                    `;
                    const trackingBlock = renderDashboardTrackingSummary(data.order);
                    const actionBlock = `
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin:0 0 16px;">
                            <div style="font-size:0.92rem;color:#6b7280;">
                                Status: <strong>${data.order?.status || 'Unknown'}</strong>
                            </div>
                            ${cancelRequestStatus === 'requested' ? `
                                <span style="padding:7px 12px;border-radius:999px;background:#fff7dd;color:#9a6700;font-size:0.78rem;font-weight:700;">
                                    Cancellation Requested
                                </span>
                            ` : ''}
                            ${canCancel ? `
                                <button class="btn btn-cancel-red dash-cancel-btn" onclick="window.openCancelRequestModal(${orderId})">
                                    Request Cancellation
                                </button>
                            ` : ''}
                        </div>
                    `;

                    const itemCards = data.items.map(item => {
                        const reviewInfo = reviewMap.get(Number(item.order_item_id)) || {};
                        const canReview = !!reviewInfo.can_review;
                        const reviewed = !!reviewInfo.is_reviewed;
                        const reviewBadge = reviewed
                            ? `<span class="dash-review-chip">${renderStarsHTML(reviewInfo.existing_rating || 0)} <span>Reviewed</span></span>`
                            : canReview
                                ? `<span class="dash-review-chip" style="background:#f8efe5;color:#8b6d57;">Ready to rate</span>`
                                : '';

                        return `
                            <div class="dash-review-item">
                                <div class="dash-review-item-top">
                                    <div>
                                        <p class="dash-review-item-name">${escapeHtml(item.name)}</p>
                                        <div class="dash-review-item-meta">Size: ${escapeHtml(item.size || 'N/A')} · Qty: ${escapeHtml(item.quantity)}</div>
                                    </div>
                                    ${reviewBadge}
                                </div>
                                <div style="display:flex;gap:14px;align-items:flex-start;">
                                    <img src="${getImageUrl(item.image_url)}" alt="${escapeHtml(item.name)}" style="width:68px;height:86px;object-fit:cover;border-radius:10px;background:#f9f9f9;">
                                    <div style="flex:1;">
                                        <div class="modal-item-price">${fmt(item.price)}</div>
                                        <p class="dash-review-item-meta" style="margin-top:8px;">${reviewed ? 'You already reviewed this item.' : canReview ? 'Tap Rate on the order card to review.' : ''}</p>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('');

                    orderItemsList.innerHTML = orderSummaryBlock + trackingBlock + actionBlock + returnBlock + `
                        <div class="dash-review-grid" style="margin-top:18px;">
                            ${itemCards}
                        </div>
                    `;

                } catch (err) {
                    console.error(err);
                    orderItemsList.innerHTML = '<p class="dash-error">Error loading items.</p>';
                }
            }

            function openCancelRequestModal(orderId, event) {
                if (event && typeof event.stopPropagation === 'function') event.stopPropagation();
                cancelRequestOrderId.value = orderId;
                cancelRequestOverlay.classList.add('open');
            }

            async function cancelDashboardOrder() {
                const orderId = Number(cancelRequestOrderId.value);
                const reason = document.querySelector('input[name="cancelReason"]:checked')?.value || '';
                const otherReason = cancelOtherReason.value.trim();

                if (!orderId) {
                    showToast('Missing order details');
                    return;
                }
                if (!reason) {
                    showToast('Please select a cancellation reason');
                    return;
                }
                if (reason === 'Other' && !otherReason) {
                    showToast('Please specify your reason');
                    return;
                }

                submitCancelRequestBtn.disabled = true;
                submitCancelRequestBtn.textContent = 'Submitting...';
                try {
                    const res = await fetch(`${API_BASE}/orders/cancel/${orderId}`, {
                        method: 'PUT',
                        headers,
                        body: JSON.stringify({
                            reason,
                            other_reason: reason === 'Other' ? otherReason : ''
                        })
                    });
                    const data = await res.json();

                    if (!data.success) {
                        showToast(data.message || 'Failed to cancel order');
                        submitCancelRequestBtn.disabled = false;
                        submitCancelRequestBtn.textContent = 'Submit Request';
                        return;
                    }

                    showToast(data.message || 'Cancellation request submitted', 'success');
                    closeCancelModal();
                    closeModal();
                    await loadOrders();
                    await loadPayments();
                } catch (err) {
                    console.error(err);
                    showToast('Network error. Please try again.');
                    submitCancelRequestBtn.disabled = false;
                    submitCancelRequestBtn.textContent = 'Submit Request';
                }
            }
            submitCancelRequestBtn?.addEventListener('click', cancelDashboardOrder);

            async function loadOrders() {
                const container = document.getElementById('dashOrdersList');
                container.innerHTML = '<div class="dash-loading"><div class="spinner"></div><p>Loading orders...</p></div>';

                try {
                    const res = await fetch(`${API_BASE}/orders`, { headers });
                    const data = await res.json();
                    if (!data.success || !data.orders || data.orders.length === 0) {
                        container.innerHTML = `
                            <div class="dash-empty-state">
                                <p>No recent orders yet.</p>
                                <a href="index.html#products" class="btn btn-primary">Start Shopping</a>
                            </div>`;
                        return;
                    }

                    const recentOrders = data.orders.slice(0, 10);
                    container.innerHTML = recentOrders.map(order => {
                        const orderIdVal = order.order_id || order.id;
                        const orderRef = String(order.invoice_number || '').trim() || `NATDEV${String(orderIdVal || 0).padStart(3, '0')}`;
                        const orderStatus = String(order.status || '').trim().toLowerCase();
                        const cancelRequestStatus = String(order.cancellation_request_status || '').trim().toLowerCase();
                        const delivered = isDeliveredOrder(order);
                        const canReviewOrder = delivered;
                        const canCancel = (orderStatus === 'pending' || orderStatus === 'paid') && cancelRequestStatus !== 'requested';
                        const returnEligibleUntil = order.return_eligible_until ? new Date(order.return_eligible_until) : null;
                        const returnDaysLeft = returnEligibleUntil ? getDaysRemaining(returnEligibleUntil) : 0;
                        const returnBadge = delivered
                            ? (returnDaysLeft > 0
                                ? `<div class="return-eligibility-notice eligible">✅ Return/Exchange available — ${returnDaysLeft} day${returnDaysLeft > 1 ? 's' : ''} left</div>`
                                : `<div class="return-eligibility-notice expired">⏰ Return/Exchange window closed</div>`)
                            : (order.status === 'Cancelled' ? '' : `<div class="return-eligibility-notice pending">↩️ Return/Exchange available after delivery</div>`);
                        const returnTrackingLabel = order.return_shiprocket_tracking_status || order.return_shiprocket_status || order.return_latest_activity || '';
                        const returnSummary = order.return_request_status ? `
                            <div style="margin-top:10px;padding:12px 14px;border-radius:14px;border:1px solid #f0e1d8;background:#fff9f6;display:grid;gap:4px;">
                                <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:space-between;">
                                    <span style="font-size:0.82rem;font-weight:700;color:#8b1e33;">Return: ${escapeHtml(order.return_request_status)}</span>
                                    ${order.refund_status ? `<span style="font-size:0.78rem;font-weight:700;color:#0f7a35;background:#eaf7ee;padding:4px 10px;border-radius:999px;">Refund: ${escapeHtml(order.refund_status)}</span>` : ''}
                                </div>
                                ${order.return_reason ? `<div style="font-size:0.8rem;color:#6f5f55;">Reason: ${escapeHtml(order.return_reason)}</div>` : ''}
                                ${order.return_shiprocket_awb_code || order.return_shiprocket_courier_name ? `<div style="font-size:0.8rem;color:#6f5f55;">${escapeHtml(order.return_shiprocket_courier_name || 'Courier')} ${order.return_shiprocket_awb_code ? `• AWB ${escapeHtml(order.return_shiprocket_awb_code)}` : ''}</div>` : ''}
                                ${returnTrackingLabel ? `<div style="font-size:0.8rem;color:#6f5f55;">Pickup / Return: ${escapeHtml(returnTrackingLabel)}</div>` : ''}
                            </div>
                        ` : '';
                        return `
                        <div class="dash-order-list-item" onclick='window.openOrderItems(${orderIdVal}, ${JSON.stringify(orderRef)})'>
                            <div class="dash-order-list-top">
                                <span class="dash-order-id">${orderRef}</span>
                                <span class="dash-status ${statusClass(order.status)}">${order.status}</span>
                            </div>
                            <div class="dash-order-list-meta">
                                <span>${fmtDate(order.created_at)}</span>
                                <span class="dash-order-amount">${fmt(order.total_amount)}</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:14px;margin-top:10px;">
                                ${order.address_line ? `<p class="dash-order-list-address" style="margin:0;flex:1;padding-right:15px;">${order.address_line}, ${order.city}, ${order.state} - ${order.pincode}</p>` : '<div style="flex:1;"></div>'}
                                <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
                                    ${cancelRequestStatus === 'requested' ? `<span style="padding:7px 12px;border-radius:999px;background:#fff7dd;color:#9a6700;font-size:0.78rem;font-weight:700;">Request Sent</span>` : ''}
                                    ${canCancel ? `<button class="btn btn-cancel-red dash-cancel-btn" onclick="window.openCancelRequestModal(${orderIdVal}, event)">Cancel</button>` : ''}
                                    ${delivered ? `<button class="btn btn-submit-green dash-cancel-btn" onclick="event.stopPropagation(); window.openOrderItems(${orderIdVal})">Return / Exchange</button>` : ''}
                                    ${canReviewOrder ? `<button type="button" class="btn-rate-review" data-order-review='${escapeHtml(JSON.stringify({ order_id: orderIdVal, order_ref: orderRef }))}'>Rate ⭐</button>` : ''}
                                    <span style="font-size: 0.75rem; color: #8b5cf6; font-weight: 600;">View Details »</span>
                                </div>
                            </div>
                            ${returnBadge}
                            ${returnSummary}
                        </div>
                    `;
                    }).join('');

                    // Expose to window for onclick
                    window.openOrderItems = openOrderItems;
                    window.cancelDashboardOrder = cancelDashboardOrder;
                    window.openCancelRequestModal = openCancelRequestModal;
                    window.openReturnRequestModal = openReturnRequestModal;
                    window.openExchangeRequestModal = openExchangeRequestModal;

                    container.querySelectorAll('.btn-rate-review[data-order-review]').forEach(btn => {
                        btn.addEventListener('click', (event) => {
                            event.stopPropagation();
                            const payload = JSON.parse(btn.dataset.orderReview);
                            openOrderReviewModal(Number(payload.order_id), payload.order_ref);
                        });
                    });

                } catch {
                    container.innerHTML = '<p class="dash-error">Failed to load orders.</p>';
                }
            }

            async function loadPayments() {
                const container = document.getElementById('dashPaymentsList');
                container.innerHTML = '<div class="dash-loading"><div class="spinner"></div><p>Loading payments...</p></div>';

                try {
                    const res = await fetch(`${API_BASE}/orders`, { headers });
                    const data = await res.json();

                    if (!data.success || !data.orders || data.orders.length === 0) {
                        container.innerHTML = '<div class="dash-empty-state"><p>No payment history yet.</p></div>';
                        return;
                    }

                    const paidOrders = data.orders.filter(order => String(order.status).toLowerCase() !== 'pending');
                    if (!paidOrders.length) {
                        container.innerHTML = '<div class="dash-empty-state"><p>No completed payments yet.</p></div>';
                        return;
                    }

                    container.innerHTML = `
                        <div class="dash-payments-table-wrap">
                            <table class="dash-payments-table">
                                <thead>
                                    <tr>
                                        <th>Order</th>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th>PayU / Refund ID</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${paidOrders.map(order => {
                        const orderIdVal = order.order_id || order.id;
                        const orderRef = String(order.invoice_number || '').trim() || `NATDEV${String(orderIdVal || 0).padStart(3, '0')}`;
                        const payuRef = String(order.gateway_payment_id || order.refund_request_id || '').trim() || '—';
                        return `
                                        <tr>
                                            <td>${orderRef}</td>
                                            <td>${fmtDate(order.created_at)}</td>
                                            <td>${fmt(order.total_amount)}</td>
                                            <td>${payuRef}</td>
                                            <td><span class="dash-status ${statusClass(order.status)}">${order.status}</span></td>
                                        </tr>
                                    `;
                    }).join('')}
                                </tbody>
                            </table>
                        </div>`;
                } catch {
                    container.innerHTML = '<p class="dash-error">Failed to load payments.</p>';
                }
            }

            async function loadAddresses() {
                const container = document.getElementById('dashAddressContent');
                container.innerHTML = '<div class="dash-loading"><div class="spinner"></div><p>Loading addresses...</p></div>';

                try {
                    const res = await fetch(`${API_BASE}/addresses`, { headers });
                    const data = await res.json();

                    if (!data.success || !data.addresses || data.addresses.length === 0) {
                        container.innerHTML = `
                            <div class="dash-empty-state">
                                <p>No addresses saved yet.</p>
                                <p class="dash-empty-hint">Add an address during checkout.</p>
                            </div>`;
                        return;
                    }

                    container.innerHTML = `
                        <div class="dash-address-list">
                            ${data.addresses.map(address => {
                                const displayAddress = normalizeAddressDisplay(address);
                                return `
                                <div class="dash-address-list-item">
                                    <div class="dash-address-row">
                                        <div class="dash-address-details">
                                            <h3>${displayAddress.displayName || 'Address'}</h3>
                                            <p>${address.address_line || ''}</p>
                                            <p>${address.city || ''}, ${address.state || ''} - ${address.pincode || ''}</p>
                                            <p class="dash-address-mobile">${displayAddress.displayPhone || ''}</p>
                                        </div>
                                        <div class="dash-address-actions">
                                            <button
                                                type="button"
                                                class="dash-address-action-btn dash-edit-addr-btn"
                                                data-addr='${JSON.stringify(address).replace(/'/g, "&#39;")}'
                                                aria-label="Edit address"
                                            >
                                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                                    <path d="M4 20h4l10.5-10.5a2.1 2.1 0 0 0 0-3L17.5 5a2.1 2.1 0 0 0-3 0L4 15.5V20z"></path>
                                                    <path d="M13.5 6.5l4 4"></path>
                                                </svg>
                                                <span>Edit</span>
                                            </button>
                                            <button
                                                type="button"
                                                class="dash-address-action-btn dash-address-delete-btn"
                                                data-address-id="${address.id}"
                                                aria-label="Delete address"
                                            >
                                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                                    <path d="M3 6h18"></path>
                                                    <path d="M8 6V4h8v2"></path>
                                                    <path d="M6 6l1 14h10l1-14"></path>
                                                    <path d="M10 11v5"></path>
                                                    <path d="M14 11v5"></path>
                                                </svg>
                                                <span>Delete</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>`;
                            }).join('')}
                        </div>`;

                    // Attach action button listeners
                    container.querySelectorAll('.dash-edit-addr-btn').forEach(btn => {
                        btn.addEventListener('click', () => {
                            const addr = JSON.parse(btn.dataset.addr);
                            openEditAddress(addr);
                        });
                    });
                    container.querySelectorAll('.dash-address-delete-btn').forEach(btn => {
                        btn.addEventListener('click', async () => {
                            const addressId = btn.dataset.addressId;
                            if (!addressId) return;

                            const ok = window.confirm('Delete this address? This cannot be undone.');
                            if (!ok) return;

                            try {
                                btn.disabled = true;
                                const originalText = btn.innerHTML;
                                btn.dataset.originalText = originalText;
                                btn.innerHTML = '<span>Deleting...</span>';

                                const res = await fetch(`${API_BASE}/addresses/${addressId}`, {
                                    method: 'DELETE',
                                    headers
                                });
                                const data = await res.json();
                                if (!data.success) {
                                    throw new Error(data.message || 'Failed to delete address');
                                }

                                showToast('Address deleted successfully', 'success');
                                await loadAddresses();
                            } catch (err) {
                                showToast(err.message || 'Failed to delete address');
                            } finally {
                                btn.disabled = false;
                                if (btn.dataset.originalText) {
                                    btn.innerHTML = btn.dataset.originalText;
                                    delete btn.dataset.originalText;
                                }
                            }
                        });
                    });
                } catch {
                    container.innerHTML = '<p class="dash-error">Failed to load addresses.</p>';
                }
            }

            // ── Address Edit Modal ──
            const addressEditOverlay = document.getElementById('addressEditOverlay');
            const closeAddressEditModal = document.getElementById('closeAddressEditModal');
            const addressEditForm = document.getElementById('addressEditForm');

            function openEditAddress(addr) {
                document.getElementById('editAddrId').value = addr.id;
                document.getElementById('editAddrName').value = addr.name || '';
                document.getElementById('editAddrMobile').value = addr.mobile || '';
                document.getElementById('editAddrLine').value = addr.address_line || '';
                document.getElementById('editAddrPincode').value = addr.pincode || '';
                document.getElementById('editAddrCity').value = addr.city || '';
                document.getElementById('editAddrState').value = addr.state || '';
                addressEditOverlay.classList.add('open');
            }

            function closeAddrEditModal() {
                addressEditOverlay.classList.remove('open');
            }

            closeAddressEditModal?.addEventListener('click', closeAddrEditModal);
            addressEditOverlay?.addEventListener('click', (e) => {
                if (e.target === addressEditOverlay) closeAddrEditModal();
            });

            addressEditForm?.addEventListener('submit', async (e) => {
                e.preventDefault();
                const saveBtn = document.getElementById('saveAddrBtn');
                const addrId = document.getElementById('editAddrId').value;
                const body = {
                    name: document.getElementById('editAddrName').value.trim(),
                    mobile: document.getElementById('editAddrMobile').value.trim(),
                    address_line: document.getElementById('editAddrLine').value.trim(),
                    pincode: document.getElementById('editAddrPincode').value.trim(),
                    city: document.getElementById('editAddrCity').value.trim(),
                    state: document.getElementById('editAddrState').value.trim()
                };

                if (!body.address_line || !body.city || !body.state || !body.pincode) {
                    showToast('Please fill all required fields');
                    return;
                }

                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';
                try {
                    const res = await fetch(`${API_BASE}/addresses/${addrId}`, {
                        method: 'PUT',
                        headers,
                        body: JSON.stringify(body)
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast('Address updated successfully', 'success');
                        closeAddrEditModal();
                        await loadAddresses();
                    } else {
                        showToast(data.message || 'Failed to update address');
                    }
                } catch {
                    showToast('Failed to connect to server');
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save Address';
                }
            });

            // Auto-fill city/state from pincode
            document.getElementById('editAddrPincode')?.addEventListener('input', async (e) => {
                const pin = e.target.value.trim();
                if (pin.length === 6) {
                    try {
                        const res = await fetch(`${API_BASE}/pincode/${pin}`);
                        const data = await res.json();
                        if (data.success) {
                            document.getElementById('editAddrCity').value = data.city || '';
                            document.getElementById('editAddrState').value = data.state || '';
                        }
                    } catch { /* ignore */ }
                }
            });

            async function loadProfile() {
                try {
                    const res = await fetch(`${API_BASE}/user/profile`, { headers });
                    const data = await res.json();
                    if (!data.success) return;

                    const user = data.user;
                    document.getElementById('profileName').value = user.name || '';
                    document.getElementById('profileEmail').value = user.email || '';
                    document.getElementById('profileMobile').value = user.mobile_number || '';
                    document.getElementById('profileCreated').value = fmtDate(user.created_at);

                    if (user.gender) {
                        const selectedGender = document.querySelector(`input[name="profileGender"][value="${user.gender}"]`);
                        if (selectedGender) selectedGender.checked = true;
                    }
                } catch {
                    showToast('Failed to load profile', 'error');
                }
            }

            document.getElementById('dashProfileForm')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                const saveBtn = document.getElementById('profileSaveBtn');
                const name = document.getElementById('profileName').value.trim();
                const email = document.getElementById('profileEmail').value.trim();
                const gender = document.querySelector('input[name="profileGender"]:checked')?.value || '';

                if (!name) {
                    showToast('Please enter your name');
                    return;
                }

                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';
                try {
                    const res = await fetch(`${API_BASE}/user/profile`, {
                        method: 'PUT',
                        headers,
                        body: JSON.stringify({ name, email, gender })
                    });
                    const data = await res.json();
                    if (!data.success) {
                        showToast(data.message || 'Failed to update profile');
                        return;
                    }

                    const localUser = getUser() || {};
                    localStorage.setItem('DEVASTHRA_user', JSON.stringify({ ...localUser, name }));
                    showToast('Profile updated successfully', 'success');
                } catch {
                    showToast('Failed to connect to server');
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save Changes';
                }
            });

            function renderSupportMessages(messages = []) {
                const headerEl = document.getElementById('userSupportHeader');
                const messagesEl = document.getElementById('userSupportMessages');
                if (!messagesEl) return;

                headerEl.textContent = 'Talk to support';
                if (!messages.length) {
                    messagesEl.innerHTML = '<div class="dash-empty-state"><p>No messages yet. Start the conversation and the admin team will reply here.</p></div>';
                    return;
                }

                messagesEl.innerHTML = messages.map(message => `
                    <div style="display:flex;justify-content:${message.sender_type === 'user' ? 'flex-end' : 'flex-start'};">
                        <div style="max-width:min(80%,520px);padding:12px 14px;border-radius:14px;background:${message.sender_type === 'user' ? '#6B0F2B' : '#fff'};color:${message.sender_type === 'user' ? '#fff' : '#111'};box-shadow:0 6px 18px rgba(0,0,0,.06);">
                            <div style="font-size:.92rem;line-height:1.5;">${escapeHtml(message.message)}</div>
                            <div style="font-size:.72rem;opacity:.8;margin-top:6px;">${fmtDate(message.created_at)}</div>
                        </div>
                    </div>
                `).join('');
                messagesEl.scrollTop = messagesEl.scrollHeight;
            }

            async function loadSupportConversation() {
                const messagesEl = document.getElementById('userSupportMessages');
                if (!messagesEl) return;
                messagesEl.innerHTML = '<div class="dash-loading"><div class="spinner"></div><p>Loading support chat...</p></div>';

                try {
                    const res = await fetch(`${API_BASE}/support/conversation`, { headers });
                    const data = await res.json();
                    if (!data.success) throw new Error(data.message || 'Failed to load support chat');
                    renderSupportMessages(data.messages || []);
                } catch (err) {
                    messagesEl.innerHTML = `<p class="dash-error">${err.message || 'Failed to load support chat'}</p>`;
                }
            }

            document.getElementById('userSupportForm')?.addEventListener('submit', async event => {
                event.preventDefault();
                const input = document.getElementById('userSupportInput');
                const message = input.value.trim();
                if (!message) return;

                try {
                    const res = await fetch(`${API_BASE}/support/messages`, {
                        method: 'POST',
                        headers,
                        body: JSON.stringify({ message })
                    });
                    const data = await res.json();
                    if (!data.success) throw new Error(data.message || 'Failed to send message');
                    input.value = '';
                    await loadSupportConversation();
                    showToast('Message sent', 'success');
                } catch (err) {
                    showToast(err.message || 'Failed to send message');
                }
            });

            setInterval(() => {
                if (document.getElementById('sec-support')?.classList.contains('active')) {
                    loadSupportConversation();
                }
            }, 5000);

            switchSection('orders');
        });
    </script>

