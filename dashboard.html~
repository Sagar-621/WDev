            document.getElementById('submitReturnBtn')?.addEventListener('click', async () => {
                const orderId = currentReturnRequest.orderId;
                const orderItemId = currentReturnRequest.orderItemId;
                const reason = document.getElementById('returnReason').value;
                const subReason = document.getElementById('returnSubReason').value.trim();
                const description = document.getElementById('returnDescription').value.trim();
                const images = document.getElementById('returnImages').files;
                const submitBtn = document.getElementById('submitReturnBtn');

                if (!orderId || !orderItemId) {
                    showToast('Unable to find this order item');
                    return;
                }
                if (!reason) {
                    showToast('Please select a reason for return');
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.textContent = 'Submitting...';

                try {
                    const formData = new FormData();
                    formData.append('order_id', orderId);
                    formData.append('order_item_id', orderItemId);
                    formData.append('reason', reason);
                    formData.append('sub_reason', subReason);
                    formData.append('description', description);
                    for (let i = 0; i < Math.min(images.length, 5); i++) {
                        formData.append('proof_images', images[i]);
                    }

                    const res = await fetch(`${API_BASE}/returns/request`, {
