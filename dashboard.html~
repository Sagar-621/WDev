                            <div style="font-size:0.92rem;color:#6b7280;">
                                Status: <strong>${data.order?.status || 'Unknown'}</strong>
                            </div>
                            ${cancelRequestStatus === 'requested' ? `
                                <span style="padding:7px 12px;border-radius:999px;background:#fff7dd;color:#9a6700;font-size:0.78rem;font-weight:700;">
                                    Cancellation Requested
                                </span>
